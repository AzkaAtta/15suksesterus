---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import SocialShares from '@components/SocialShares.astro'
import BreakoutImage from '@components/BreakoutImage.astro'
import { Image } from 'astro:assets'

// 1. Mengambil data dari file lokal (.md) alih-alih API eksternal
export async function getStaticPaths() {
  const posts = await Astro.glob('./*.md');

  return posts.map((post) => {
    // Membuat slug URL dari judul artikel jika file tidak punya slug bawaan
    const slug = post.frontmatter.title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)+/g, '');

    return {
      params: { post: slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;

// Menyesuaikan author
const author = {
  name: frontmatter.author || 'Tim Aura Digital',
  image: '/logo-auradigital.png', // Sesuaikan dengan logo Anda
  bio: 'Pakar optimasi sosial media & digital marketing.',
};
---

<DefaultLayout 
  title={frontmatter.title} 
  description={frontmatter.description} 
  url={`https://auradigital.id/blog/${Astro.params.post}`}
>
  <PageHeader
    title={frontmatter.title}
    subtitle={frontmatter.description}
    author={author}
    bgType="bordered"
    featuredImage={frontmatter.image || '/og-home.png'}
  />
  
  <section class="my-12">
    <div class="narrow space-content container prose prose-lg max-w-none dark:prose-invert">
      <Content />
    </div>
  </section>

  <section class="my-12">
    <div class="narrow space-content container">
      <h2>Bagikan Artikel Ini</h2>
      <p>Bermanfaat? Jangan lupa bagikan tips ini ke rekan bisnis Anda!</p>
      <SocialShares />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  // Opsional: Anda bisa menambahkan styling khusus untuk konten blog di sini
  .prose {
    h2 {
      margin-top: 2em;
      margin-bottom: 0.5em;
    }
    p {
      margin-bottom: 1.25em;
      line-height: 1.8;
    }
    a {
      color: var(--link-color);
      text-decoration: underline;
    }
  }
</style>
